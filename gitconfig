	name = Patrik Votocek
	email = patrik@votocek.cz
	signingkey = 13443642BFF2770A
[core]
	editor = nvim
	excludesfile = ~/.gitignore
[diff]
	tool = nvim -d
[difftool]
	prompt = false
[push]
	followTags = true
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[init]
	defaultBranch = main
[color]
	ui = true
	branch = true
	diff = true
	interactive = true
	status = true
[format]
	pretty = oneline
